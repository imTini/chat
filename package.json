{
  "name": "chat",
  "version": "1.1.0",
  "description": "Basic chat; now with logging.",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "license": "ISC",
  "author": "Martin Jude",
  "scripts": {
    "postinstall": "npm run models:pull",
    "models:pull": "node-llama-cpp pull --dir ./models hf:ggml-org/MiniCPM-V-4.6-GGUF hf:unsloth/Qwen3.5-2B-GGUF hf:hugging-quants/Llama-3.2-1B-Instruct-Q8_0-GGUF hf:zai-org/GLM-OCR",
    "dev": "concurrently \"npm --prefix apps/api run dev\" \"npm --prefix apps/web run dev\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "seed": "npm --prefix apps/api run seed",
    "build": "npm --prefix apps/api run build && npm --prefix apps/web run build",
    "start": "npm --prefix apps/api run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
