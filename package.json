{
  "name": "chat",
  "version": "1.0.0",
  "description": "Basic chat",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "license": "ISC",
  "author": "Martin Jude",
  "scripts": {
    "dev": "concurrently \"npm --prefix apps/api run dev\" \"npm --prefix apps/web run dev\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/api run build && npm --prefix apps/web run build",
    "start": "npm --prefix apps/api run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
