# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, development):
#   Leave DATABASE_URL unset or omit it entirely.
# PostgreSQL (production):
#   Set DATABASE_URL and NODE_ENV=production.
NODE_ENV=production
DATABASE_URL=postgresql://user:password@localhost:5432/chat

# ── Auth seed ──────────────────────────────────────────────────────────────────
# First-run user created by `npm run seed`.
SEED_USERNAME=admin
SEED_PASSWORD=changeme

# ── Model ──────────────────────────────────────────────────────────────────────
# Filename (relative to ./models/) or absolute path.
# MODEL_PATH=gemma-4-E4B-it-Q3_K_S.gguf

# ── LLM performance tuning ─────────────────────────────────────────────────────
# Max CPU threads used by llama.cpp across all sessions.
# Defaults to (number of CPU cores - 1). Set to 0 for no limit.
# LLAMA_MAX_THREADS=3

# Max number of sessions whose LlamaContext is held in RAM simultaneously.
# Least-recently-used sessions are evicted (persisted to DB) when the cap is hit.
# Each session at 4096 tokens uses ~450 MB on Gemma 4B — tune to your RAM budget.
# Defaults to 4.
# MAX_ACTIVE_SESSIONS=4

# Max context size (tokens) per session. Larger = more RAM per session.
# Defaults to 4096.
# MAX_CONTEXT_SIZE=4096
